  Descryption: "\u041A\u0430\u0436\u0435\u0442\u0441\u044F \u0432\u0430\u0448\u0438
    \u0434\u0430\u043D\u043D\u044B\u0435 \u0431\u044B\u043B\u0438 \u0443\u043A\u0440\u0430\u0434\u0435\u043D\u044B!
    \u041D\u0438\u043A\u043E\u0433\u0434\u0430 \u043D\u0435 \u0437\u0430\u0431\u044B\u0432\u0430\u0439\u0442\u0435,
    \u0447\u0442\u043E \u043C\u043E\u0448\u0435\u043D\u043D\u0438\u043A\u0438 \u043B\u044E\u0431\u044F\u0442,
    \u043F\u0440\u0438\u043A\u0438\u0434\u044B\u0432\u0430\u044F\u0441\u044C \u0432\u0430\u0448\u0438\u043C\u0438
    \u0431\u043B\u0438\u0437\u043A\u0438\u043C\u0438, \u043F\u044B\u0442\u0430\u0442\u044C\u0441\u044F
    \u0447\u0435\u0440\u0435\u0437 \u0444\u0438\u0448\u0438\u043D\u0433\u043E\u0432\u044B\u0435
    \u0441\u0441\u044B\u043B\u043A\u0438 \u0443\u043A\u0440\u0430\u0441\u0442\u044C
    \u0432\u0430\u0448\u0438 \u0434\u0430\u043D\u043D\u044B\u0435!"
